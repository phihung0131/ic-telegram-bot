# ====================== TELEGRAM (nguồn tín hiệu) ======================
TELEGRAM_API_ID=123456
TELEGRAM_API_HASH=xxxxxxxxxxxxxxxxxxxxxxxxxxxx
TARGET_GROUP_ID=-1001818116871          # channel/group chứa tín hiệu XAUUSD

# ====================== TELEGRAM (bot notify cá nhân) ======================
BOT_NOTIFY_TOKEN=123456:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTIFY_CHAT_ID=123456789

# Channel test riêng để ping healthcheck (tùy chọn, để trống nếu không dùng)
HEALTHCHECK_CHANNEL_ID=

# ====================== CHẾ ĐỘ SANDBOX / REAL ======================
# True = dùng bộ CT_*_DEMO bên dưới, False = dùng bộ CT_*_REAL
CT_SANDBOX_MODE=True

# ---- Tài khoản DEMO ----
CT_HOST_DEMO=demo-uk-eqx-01.p.c-trader.com
CT_QUOTE_PORT_DEMO=5211
CT_TRADE_PORT_DEMO=5212
CT_SENDER_COMPID_DEMO=demo.icmarkets.10080457
CT_TARGET_COMPID_DEMO=cServer
CT_PASSWORD_DEMO=your_demo_password
CT_ACCOUNT_DEMO=10080457

# ---- Tài khoản REAL ----
CT_HOST_REAL=
CT_QUOTE_PORT_REAL=5211
CT_TRADE_PORT_REAL=5212
CT_SENDER_COMPID_REAL=
CT_TARGET_COMPID_REAL=cServer
CT_PASSWORD_REAL=
CT_ACCOUNT_REAL=

# Dùng SSL (True) hay plain text (False). Nên luôn để True.
CT_USE_SSL=True
CT_HEARTBEAT_SEC=30
# Số giây chờ giữa các lần tự động kết nối lại khi FIX session bị mất kết nối
# ngoài ý muốn (server đóng socket, nhận Logout...). Retry vô hạn cho tới khi
# thành công, KHÔNG áp dụng khi bot chủ động đóng session (vd lúc tắt bot).
CT_RECONNECT_DELAY_SEC=30

# ====================== SYMBOL / KHỐI LƯỢNG / TP-SL ======================
CT_SYMBOL=XAUUSD
# Một số broker cTrader FIX yêu cầu Symbol ID dạng số thay vì chuỗi "XAUUSD".
# Để trống nếu broker chấp nhận string; nếu không, điền ID số lấy được từ
# SecurityList response (35=y) rồi điền vào đây - xem README.
CT_SYMBOL_ID=

# TP = entry ± TP_OFFSET (đơn vị giá trực tiếp, KHÔNG phải pips). Vd TP_OFFSET=10
# nghĩa là entry 4155.0 -> TP = 4165.0 (BUY) hoặc 4145.0 (SELL).
TP_OFFSET=10
PIP_SIZE=0.1
# Khối lượng cố định mỗi lệnh (đơn vị lot theo quy ước của broker, vd 0.01 = 1000oz tuỳ broker)
FIXED_VOLUME=0.01

# Sai số (giá) khi so khớp lệnh "hủy setup XXXX" với các lệnh đang mở
SETUP_MATCH_TOLERANCE=0.5

# ====================== LOGGING ======================
LOG_DIR=
LOG_LEVEL=INFO
TELETHON_LOG_LEVEL=WARNING